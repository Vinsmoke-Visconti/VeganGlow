{
  "name": "veganglow-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "VeganGlow — Fullstack Monorepo (Web, Mobile, Backend)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "// --- DEV ---": "",
    "dev": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run sync --workspace=apps/mobile",
    "// --- BUILD ---": "",
    "build": "npm run build --workspace=apps/web",
    "build:all": "npm run build --workspaces --if-present",
    "// --- LINT & TYPE ---": "",
    "lint": "npm run lint --workspace=apps/web",
    "type-check": "npm run type-check --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "// --- DATABASE ---": "",
    "db:push": "npm run db:push --workspace=apps/backend",
    "db:types": "npm run db:types --workspace=apps/backend",
    "db:reset": "npm run db:reset --workspace=apps/backend",
    "// --- FUNCTIONS ---": "",
    "functions:deploy": "npm run functions:deploy --workspace=apps/backend",
    "functions:serve": "npm run functions:serve --workspace=apps/backend",
    "// --- DEPLOY ---": "",
    "deploy": "bash scripts/deploy.sh",
    "docker:dev": "docker compose -f docker/docker-compose.yml up --build",
    "docker:prod": "docker compose -f docker/docker-compose.prod.yml up --build -d"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["eslint --fix", "prettier --write"],
    "*.{json,css,md}": ["prettier --write"]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}

