{
  "name": "@veganglow/backend",
  "version": "1.0.0",
  "private": true,
  "description": "VeganGlow Backend — Supabase Schema, Migrations, Edge Functions",
  "scripts": {
    "db:push": "supabase db push --linked",
    "db:reset": "supabase db reset",
